#!name=Script
#!desc=HTTP Script Module.

[MITM]
hostname = %INSERT% *.googlevideo.com,api.weibo.cn, mapi.weibo.com, *.uve.weibo.com,*.amemv.com,api.zhihu.com, mp.weixin.qq.com, api.m.jd.com, trade-acs.m.taobao.com, ap*.intsig.net,api.vuevideo.net,i.weread.qq.com,app.bilibili.com, api.bilibili.com, api.live.bilibili.com

[Script]
# Remove Ads + Unlock Premium.

# > YouTube 
YouTube.js = script-path=https://Choler.github.io/Surge/Script/YouTube.js,pattern=^https://[\s\S]*\.googlevideo\.com/.*&(oad|ctier),type=http-request

# > 微博 (By yichahucha)
wb_ad.js = requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/wb_ad.js,pattern=^https?://m?api\.weibo\.c(n|om)/2/(statuses/(unread|extend|positives/get|(friends|video)(/|_)timeline)|stories/(video_stream|home_list)|(groups|fangle)/timeline|profile/statuses|comments/build_comments|photo/recommend_list|service/picfeed|searchall|cardlist|page|\!/photos/pic_recommend_status),type=http-response
wb_launch.js = requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/wb_launch.js,pattern=^https?://(sdk|wb)app\.uve\.weibo\.com(/interface/sdk/sdkad.php|/wbapplua/wbpullad.lua),type=http-response

# > 抖音
Aweme.js = type=http-request,pattern="^https?:\/\/.*\.amemv\.com\/aweme\/v.*\/(feed|post)",script-path=https://Choler.github.io/Surge/Script/Aweme.js,script-update-interval=0
Aweme.js = type=http-response,pattern="^https?:\/\/.*\.amemv\.com\/aweme\/v.*\/(feed|post)",requires-body=1,max-size=0,script-path=https://Choler.github.io/Surge/Script/Aweme.js,script-update-interval=0

# > 知乎 (By Primovist)
http-response ^https?:\/\/api\.zhihu\.com\/(moments\?|topstory\/recommend|.*\/questions|market\/header) requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/ydzydzydz/Rules/master/Surge/resources/script/zhihu.js

# > 微信公众号 (By Choler)
http-request ^https://mp\.weixin\.qq\.com/mp/getappmsgad script-path=https://Choler.github.io/Surge/Script/WeChat.js

# > Display jd historical price
jd_price.js = requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/jd_price.js,script-update-interval=0,pattern=^https?://api\.m\.jd\.com/client\.action\?functionId=(wareBusiness|serverConfig),type=http-response

# > Display taobao historical price
tb_price.js = requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/tb_price.js,pattern=^https?://amdc\.m\.taobao\.com/amdc/mobileDispatch,type=http-response
tb_price.js = requires-body=1,script-path=https://raw.githubusercontent.com/yichahucha/surge/master/tb_price.js,pattern=^https://trade-acs\.m\.taobao\.com/gw/mtop\.taobao\.detail\.getdetail,type=http-response

# > CamScanner unlocks pro, Cloud scanning is not available.
CamScanner.js = requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Surge/JS/CamScanner.js,script-update-interval=0,pattern=^https:\/\/(api|api-cs)\.intsig\.net\/purchase\/cs\/query_property\?,type=http-response

# > VUE video
http-response https:\/\/api\.vuevideo\.net\/api\/v1\/(users\/.+\/profile|subtitle\/prepare) requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Surge/JS/VUE.js

# 微信读书
weixinyuedu.js = type=http-response,pattern="^https?:\/\/i\.weread\.qq\.com\/pay\/memberCardSummary",requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/imxh/js/master/weixinyuedu.js,script-update-interval=0

# 哔哩哔哩
surge%20bilibili%20tab.js = type=http-response,pattern="^https?:\/\/app.bilibili.com/x/resource/show/tab\?access_key",requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/onewayticket255/Surge-Script/master/surge%20bilibili%20tab.js,script-update-interval=0
surge%20bilibili%20feed.js = type=http-response,pattern="^https?:\/\/app.bilibili.com/x/v2/feed/index\?access_key",requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/onewayticket255/Surge-Script/master/surge%20bilibili%20feed.js,script-update-interval=0
surge%20bilibili%20view%20relate.js = type=http-response,pattern="^https?:\/\/app.bilibili.com/x/v2/view\?access_key",requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/onewayticket255/Surge-Script/master/surge%20bilibili%20view%20relate.js,script-update-interval=0
surge%20bilibili%20reply.js = type=http-response,pattern="^https?:\/\/api.bilibili.com/x/v2/reply/main\?access_key",requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/onewayticket255/Surge-Script/master/surge%20bilibili%20reply.js,script-update-interval=0
surge%20bilibili%20live.js = type=http-response,pattern="^https?:\/\/api.live.bilibili.com/xlive/app-room/v1/index/getInfoByRoom\?access_key",requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/onewayticket255/Surge-Script/master/surge%20bilibili%20live.js,script-update-interval=0
