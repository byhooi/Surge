#!name=❀ scriptName
#!category=Record module
#!desc=scriptName多账号重放及获取token脚本
#!arguments=scriptName:scriptName,ckName:ckName,cron:30 8 * * *,hostname:hostname,regx:regx,path:"",bodyRegx:"",isGetCookie:1,accountIndex:0
#!arguments-desc= [参数设置]\n ├ scriptName: 脚本名称，默认由捷径生成\n ├ ckName: 变量名称，默认由捷径生成\n ├ cron: 定时运行，默认30 8 * * *\n ├ hostname: mitm域名，默认由捷径生成\n ├ regx: 匹配正则，默认由捷径生成\n ├ isGetCookie:获取ck开关，0关闭，1打开\n ├ accountIndex: 账号数组下标，默认为0\n ├ bodyRegx: 正则匹配body，默认留空\n └ path: 通知result的子路径，为空则返回全部

[Script]
{{{scriptName}}}_获取cookie = type=http-request,pattern={{{regx}}},script-path=https://raw.githubusercontent.com/byhooi/Surge/main/Script/surgeRecordMulti.js,requires-body=1,max-size=0,argument="scriptName={{{scriptName}}}&ckName={{{ckName}}}&path={{{path}}}&isGetCookie={{{isGetCookie}}}&accountIndex={{{accountIndex}}}&bodyRegx={{{bodyRegx}}}"

{{{scriptName}}} = type=cron,cronexp="{{{cron}}}",script-path=https://raw.githubusercontent.com/byhooi/Surge/main/Script/surgeRecordMulti.js,script-update-interval=0,timeout=3600,wake-system=1,engine=jsc,argument="scriptName={{{scriptName}}}&ckName={{{ckName}}}&path={{{path}}}&isGetCookie={{{isGetCookie}}}&accountIndex={{{accountIndex}}}&bodyRegx={{{bodyRegx}}}"

[MITM]
hostname = %APPEND% {{{hostname}}}
